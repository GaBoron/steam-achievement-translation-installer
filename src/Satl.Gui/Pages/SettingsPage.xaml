<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Satl_Gui.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Page.Resources>
        <Style x:Key="SettingsRowStyle" TargetType="Grid">
            <Setter Property="MinHeight" Value="88" />
            <Setter Property="Padding" Value="20,16" />
            <Setter Property="ColumnSpacing" Value="32" />
        </Style>
    </Page.Resources>
    <ScrollViewer>
        <StackPanel Padding="32,24,32,32" Spacing="12" MaxWidth="960" HorizontalAlignment="Stretch">
            <StackPanel Spacing="4">
                <TextBlock Text="设置" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="管理安装器使用的目录、连接方式和外观。更改会立即生效。" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <TextBlock Text="路径" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,12,0,0" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <Grid Style="{StaticResource SettingsRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="400" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="Steam 目录" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="用于扫描已安装游戏和成就缓存。" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
                            <TextBlock x:Name="SteamDirectoryText" TextTrimming="CharacterEllipsis" AutomationProperties.Name="当前 Steam 目录" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button Content="自动检测" Click="ResetSteamDirectory_Click" />
                                <Button Content="浏览…" Click="BrowseSteamDirectory_Click" AutomationProperties.Name="选择 Steam 目录" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="20,0" />
                    <Grid Style="{StaticResource SettingsRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="400" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="SATL 数据目录" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="保存目录缓存、安装状态、备份与恢复归档。" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
                            <TextBlock x:Name="DataDirectoryText" TextTrimming="CharacterEllipsis" AutomationProperties.Name="当前 SATL 数据目录" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                <Button Content="使用默认目录" Click="ResetDataDirectory_Click" />
                                <Button Content="打开" Click="OpenData_Click" AutomationProperties.Name="在文件资源管理器中打开数据目录" />
                                <Button Content="浏览…" Click="BrowseDataDirectory_Click" AutomationProperties.Name="选择 SATL 数据目录" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="首选项" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,12,0,0" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <Grid Style="{StaticResource SettingsRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="离线模式" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="启用后仅使用本地已验证缓存，不访问在线目录。" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="OfflineSwitch" Grid.Column="1" VerticalAlignment="Center" OffContent="关" OnContent="开" Toggled="OfflineSwitch_Toggled" />
                    </Grid>
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="20,0" />
                    <Grid Style="{StaticResource SettingsRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="应用主题" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="选择跟随 Windows，或固定使用浅色、深色主题。" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ComboBox x:Name="ThemeBox" Grid.Column="1" Width="160" VerticalAlignment="Center" SelectedIndex="0" SelectionChanged="ThemeBox_SelectionChanged">
                            <ComboBoxItem Content="跟随系统" Tag="system" />
                            <ComboBoxItem Content="浅色" Tag="light" />
                            <ComboBoxItem Content="深色" Tag="dark" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="日志" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,12,0,0" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <Grid Style="{StaticResource SettingsRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="记录运行日志" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="记录扫描、安装、恢复、缓存和异常信息，不记录成就文件内容。" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="LoggingSwitch" Grid.Column="1" VerticalAlignment="Center" OffContent="关" OnContent="开" Toggled="LoggingSwitch_Toggled" />
                    </Grid>
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="20,0" />
                    <Grid Style="{StaticResource SettingsRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="详细程度" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="标准模式记录操作结果；详细模式额外记录 CLI 事件。" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ComboBox x:Name="LogLevelBox" Grid.Column="1" Width="160" VerticalAlignment="Center" SelectedIndex="0" SelectionChanged="LogSettings_SelectionChanged">
                            <ComboBoxItem Content="标准" Tag="standard" />
                            <ComboBoxItem Content="详细" Tag="detailed" />
                        </ComboBox>
                    </Grid>
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="20,0" />
                    <Grid Style="{StaticResource SettingsRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="自动换行" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="根据窗口宽度换行显示较长的日志内容。" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="LogWordWrapSwitch" Grid.Column="1" VerticalAlignment="Center" OffContent="关" OnContent="开" Toggled="LogWordWrapSwitch_Toggled" />
                    </Grid>
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="20,0" />
                    <Grid Style="{StaticResource SettingsRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="保留时间" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="启动和设置变更时自动清理超过期限的日志。" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <ComboBox x:Name="LogRetentionBox" Width="120" SelectedIndex="1" SelectionChanged="LogSettings_SelectionChanged">
                                <ComboBoxItem Content="7 天" Tag="7" />
                                <ComboBoxItem Content="30 天" Tag="30" />
                                <ComboBoxItem Content="90 天" Tag="90" />
                            </ComboBox>
                            <Button Content="打开目录" Click="OpenLogs_Click" AutomationProperties.Name="在文件资源管理器中打开日志目录" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="软件更新" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,12,0,0" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <Grid Style="{StaticResource SettingsRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="启动时检查更新" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock Text="启动后检查 GitHub Releases；只有发现新版本时才提醒。" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch x:Name="UpdateCheckSwitch" Grid.Column="1" VerticalAlignment="Center" OffContent="关" OnContent="开" Toggled="UpdateCheckSwitch_Toggled" />
                    </Grid>
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" Margin="20,0" />
                    <Grid Style="{StaticResource SettingsRowStyle}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center" Spacing="3">
                            <TextBlock Text="检查软件更新" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <TextBlock x:Name="UpdateStatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                            <Button Content="检查更新" Click="CheckForUpdates_Click" AutomationProperties.Name="检查软件更新" />
                            <Button x:Name="OpenReleaseButton" Content="打开下载页" Click="OpenRelease_Click" Visibility="Collapsed" AutomationProperties.Name="打开 GitHub Release 下载页" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="维护" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,12,0,0" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid Style="{StaticResource SettingsRowStyle}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="3">
                        <TextBlock Text="翻译目录缓存" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="从数据源重新获取可用翻译和版本信息。" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="立即刷新" VerticalAlignment="Center" Click="RefreshCache_Click" />
                </Grid>
            </Border>

            <TextBlock Text="关于" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,12,0,0" />
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <Grid Style="{StaticResource SettingsRowStyle}">
                    <StackPanel VerticalAlignment="Center" Spacing="3">
                        <TextBlock Text="Steam 成就翻译安装器" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Name="AboutVersionText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
