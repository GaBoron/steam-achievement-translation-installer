<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Satl_Gui.Pages.GamesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:models="using:Satl_Gui.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid x:Name="PageLayout" Padding="32,24,32,16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Spacing="4">
            <TextBlock Text="可用翻译" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock Text="扫描本地 Steam 游戏，选择需要安装的成就翻译。" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
        <CommandBar Grid.Row="1" DefaultLabelPosition="Right" IsDynamicOverflowEnabled="True">
            <CommandBar.Content>
                <AutoSuggestBox
                    Width="300"
                    PlaceholderText="搜索游戏名称或 App ID"
                    QueryIcon="Find"
                    Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    AutomationProperties.Name="搜索游戏" />
            </CommandBar.Content>
            <AppBarButton Icon="Refresh" Label="重新扫描" Click="Refresh_Click" />
            <AppBarButton Icon="Download" Label="安装所选" Click="Install_Click" />
        </CommandBar>
        <ListView
            Grid.Row="2"
            ItemsSource="{x:Bind ViewModel.VisibleGames, Mode=OneWay}"
            SelectionMode="None"
            IsItemClickEnabled="False">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,0,8" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:GameItem">
                    <Border
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox
                                VerticalAlignment="Center"
                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                AutomationProperties.Name="{x:Bind GameName}" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="{x:Bind GameName}" TextTrimming="CharacterEllipsis" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                <TextBlock Text="{x:Bind Subtitle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind CatalogText}" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" />
                                    <TextBlock Text="{x:Bind StateText}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" />
                                </StackPanel>
                            </StackPanel>
                            <ComboBox
                                Grid.Column="2"
                                Width="220"
                                VerticalAlignment="Center"
                                Header="翻译版本"
                                ItemsSource="{x:Bind Variants}"
                                SelectedItem="{x:Bind SelectedVariant, Mode=TwoWay}"
                                AutomationProperties.Name="选择翻译版本" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup>
                <VisualState x:Name="Wide" />
                <VisualState x:Name="Narrow">
                    <VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="0" /></VisualState.StateTriggers>
                    <VisualState.Setters><Setter Target="PageLayout.Padding" Value="16,16,16,8" /></VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Comfortable">
                    <VisualState.StateTriggers><AdaptiveTrigger MinWindowWidth="800" /></VisualState.StateTriggers>
                    <VisualState.Setters><Setter Target="PageLayout.Padding" Value="32,24,32,16" /></VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>
    </Grid>
</Page>
