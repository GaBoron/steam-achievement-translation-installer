<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Satl_Gui.Controls.NetworkSettingsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="8">
        <Border
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel>
                <Grid MinHeight="88" Padding="20,16" ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="3">
                        <TextBlock Text="DNS 解析" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock
                            Text="默认使用 Windows DNS；需要时可指定自定义 DNS 服务器。"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <ComboBox
                        x:Name="DnsModeBox"
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        SelectionChanged="ModeBox_SelectionChanged">
                        <ComboBoxItem Content="跟随系统" Tag="system" />
                        <ComboBoxItem Content="自定义 DNS" Tag="custom" />
                    </ComboBox>
                </Grid>
                <StackPanel
                    x:Name="CustomDnsPanel"
                    Visibility="Collapsed">
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <StackPanel Padding="20,16" Spacing="8">
                        <TextBox
                            x:Name="DnsServersBox"
                            Header="DNS 服务器"
                            PlaceholderText="1.1.1.1; 8.8.8.8"
                            LostFocus="Field_LostFocus"
                            AutomationProperties.Name="自定义 DNS 服务器" />
                        <TextBlock
                            Text="多个地址用分号分隔；支持 IPv4、IPv6 和自定义端口。"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontSize="12"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel>
                <Grid MinHeight="88" Padding="20,16" ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="180" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="3">
                        <TextBlock Text="网络代理" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock
                            Text="跟随 Windows 代理、直接连接，或使用手动代理。"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <ComboBox
                        x:Name="ProxyModeBox"
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        SelectionChanged="ModeBox_SelectionChanged">
                        <ComboBoxItem Content="跟随系统" Tag="system" />
                        <ComboBoxItem Content="不使用代理" Tag="direct" />
                        <ComboBoxItem Content="手动代理" Tag="manual" />
                    </ComboBox>
                </Grid>
                <StackPanel
                    x:Name="ManualProxyPanel"
                    Visibility="Collapsed">
                    <Border Height="1" Background="{ThemeResource CardStrokeColorDefaultBrush}" />
                    <StackPanel Padding="20,16" Spacing="8">
                        <TextBox
                            x:Name="ProxyAddressBox"
                            Header="代理地址"
                            PlaceholderText="http://127.0.0.1:7890"
                            LostFocus="Field_LostFocus"
                            AutomationProperties.Name="手动代理地址" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="ProxyUsernameBox"
                                Header="用户名（可选）"
                                LostFocus="Field_LostFocus" />
                            <PasswordBox
                                x:Name="ProxyPasswordBox"
                                Grid.Column="1"
                                Header="密码（可选）"
                                LostFocus="Field_LostFocus" />
                        </Grid>
                        <TextBlock
                            Text="代理密码使用当前 Windows 账户加密保存，不会写入日志。"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontSize="12"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid MinHeight="72" Padding="20,12" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Spacing="3">
                    <TextBlock Text="连接测试" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock
                        x:Name="TestStatusText"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="验证翻译目录和软件更新服务是否可访问。"
                        TextWrapping="Wrap" />
                </StackPanel>
                <Button
                    x:Name="TestConnectionButton"
                    Grid.Column="1"
                    Content="测试网络连接"
                    VerticalAlignment="Center"
                    Click="TestConnectionButton_Click"
                    AutomationProperties.Name="测试翻译源和更新源的网络连接" />
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
